<Window x:Class="XanderVideoPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="My Custom Player" Height="720" Width="1280" Background="Black"
        Icon="pack://application:,,,/icon.ico"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <vlc:VideoView x:Name="videoView" Grid.Row="0" Margin="0,0,0,120" />

        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="Auto" MinHeight="120" Background="Black" ClipToBounds="False">
            <Grid>
                <ProgressBar x:Name="ExtractionProgress" Height="4" VerticalAlignment="Top" 
                             Background="Transparent" BorderThickness="0" Foreground="#1E90FF"
                             IsIndeterminate="True" Visibility="Collapsed" />
                <TextBlock x:Name="SubtitleText" 
                           Text="Open a video file to begin..." 
                           Foreground="White" FontSize="32" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="900">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="SubTransform" Y="0" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </Border>

        <Grid x:Name="ControlsGrid" Grid.Row="1" Height="50" Background="#202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" x:Name="StatsColumn"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OpenFileBtn" Grid.Column="0" Content="Open Video" Foreground="White" Background="#1E90FF" 
                    BorderThickness="0" Margin="10,5,5,5" Width="75" FontWeight="Bold" Click="OpenFileBtn_Click" Focusable="False"/>

            <Button x:Name="LoadSubBtn" Grid.Column="1" Content="Load .SRT" Foreground="White" Background="#FF8C00" 
                    BorderThickness="0" Margin="5,5,5,5" Width="70" FontWeight="Bold" Click="LoadSubBtn_Click" Focusable="False"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="5,5,10,5" VerticalAlignment="Center">
                <TextBlock Text="Sub Pos:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Slider x:Name="SubPosSlider" Width="80" Minimum="-500" Maximum="100" Value="0" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="SubPosSlider_ValueChanged" Focusable="False"/>
            </StackPanel>

            <Button x:Name="PlayPauseBtn" Grid.Column="3" Content="Play" Foreground="White" Background="#404040" 
                    BorderThickness="0" Margin="5,5,0,5" Width="60" Click="PlayPauseBtn_Click" Focusable="False"/>

            <Button x:Name="SkipBtn" Grid.Column="4" Content="+10s" Foreground="White" Background="#404040" 
                    BorderThickness="0" Margin="5,5,5,5" Width="50" Click="SkipBtn_Click" Focusable="False"/>

            <Slider x:Name="TimelineSlider" Grid.Column="5" Minimum="0" Margin="10,0" 
                    VerticalAlignment="Center" IsMoveToPointEnabled="True"
                    Thumb.DragStarted="TimelineSlider_DragStarted"
                    Thumb.DragCompleted="TimelineSlider_DragCompleted"
                    ValueChanged="TimelineSlider_ValueChanged" Focusable="False"/>

            <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="5">
                <TextBlock Text="Audio:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="AudioCombo" Width="100" SelectionChanged="AudioCombo_SelectionChanged" Margin="0,0,10,0"/>
            </StackPanel>

            <StackPanel Grid.Column="7" Orientation="Horizontal" Margin="5,5,10,5">
                <TextBlock Text="Internal Sub:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="SubTrackCombo" Width="120" SelectionChanged="SubTrackCombo_SelectionChanged" SelectedIndex="0">
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,10,0">
                <TextBlock x:Name="SizeStatus" Text="S:32" Foreground="#888888" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="HeightStatus" Text="H:0" Foreground="#888888" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="WidthStatus" Text="W:900" Foreground="#888888" FontSize="11"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>