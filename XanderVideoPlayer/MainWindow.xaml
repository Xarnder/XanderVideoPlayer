<Window x:Class="XanderVideoPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="My Custom Player" Height="720" Width="1280" Background="Black"
        Icon="pack://application:,,,/icon.ico"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="VideoContainer" Grid.Row="0" ClipToBounds="True" Panel.ZIndex="0">
            <vlc:VideoView x:Name="videoView" RenderTransformOrigin="0.5, 0.5">
                <vlc:VideoView.RenderTransform>
                    <ScaleTransform x:Name="VideoScale" ScaleX="1" ScaleY="1" />
                </vlc:VideoView.RenderTransform>
                
                <Grid>
                    <Border x:Name="TopCropRect" VerticalAlignment="Top" Height="0" Background="Black" BorderBrush="Transparent" BorderThickness="0,0,0,2" Panel.ZIndex="100" />

                    <Border x:Name="SubtitleAreaBorder" VerticalAlignment="Bottom" Height="Auto" MinHeight="120" Background="Black" BorderBrush="Transparent" BorderThickness="0,2,0,0" ClipToBounds="False" Panel.ZIndex="99">
                        <Grid>
                            <ProgressBar x:Name="ExtractionProgress" Height="4" VerticalAlignment="Top" 
                                         Background="Transparent" BorderThickness="0" Foreground="#1E90FF"
                                         IsIndeterminate="True" Visibility="Collapsed" />
                            <TextBlock x:Name="SubtitleText" 
                                       Text="Open a video file to begin..." 
                                       Foreground="White" FontSize="32" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="900">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="SubTransform" Y="0" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </vlc:VideoView>
        </Border>

        <Grid x:Name="ControlsGrid" Grid.Row="1" Height="50" Background="#202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" x:Name="FullscreenColumn"/>
                <ColumnDefinition Width="Auto" x:Name="HelpColumn"/>
                <ColumnDefinition Width="Auto" x:Name="StatsColumn"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OpenFileBtn" Grid.Column="0" Content="Open Video" Foreground="White" Background="#1E90FF" 
                    BorderThickness="0" Margin="10,5,5,5" Width="75" FontWeight="Bold" Click="OpenFileBtn_Click" Focusable="False"/>

            <Button x:Name="LoadSubBtn" Grid.Column="1" Content="Load .SRT" Foreground="White" Background="#FF8C00" 
                    BorderThickness="0" Margin="5,5,5,5" Width="70" FontWeight="Bold" Click="LoadSubBtn_Click" Focusable="False"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="5,5,10,5" VerticalAlignment="Center">
                <TextBlock Text="Sub Pos:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Slider x:Name="SubPosSlider" Width="80" Minimum="-500" Maximum="100" Value="0" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="SubPosSlider_ValueChanged" Focusable="False"/>
            </StackPanel>

            <Button x:Name="PlayPauseBtn" Grid.Column="3" Content="Play" Foreground="White" Background="#404040" 
                    BorderThickness="0" Margin="5,5,0,5" Width="60" Click="PlayPauseBtn_Click" Focusable="False"/>

            <Button x:Name="SkipBtn" Grid.Column="4" Content="+10s" Foreground="White" Background="#404040" 
                    BorderThickness="0" Margin="5,5,5,5" Width="50" Click="SkipBtn_Click" Focusable="False"/>

            <Slider x:Name="TimelineSlider" Grid.Column="5" Minimum="0" Margin="10,0" 
                    VerticalAlignment="Center" IsMoveToPointEnabled="True"
                    Thumb.DragStarted="TimelineSlider_DragStarted"
                    Thumb.DragCompleted="TimelineSlider_DragCompleted"
                    ValueChanged="TimelineSlider_ValueChanged" Focusable="False"/>

            <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="5">
                <TextBlock Text="Audio:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="AudioCombo" Width="100" SelectionChanged="AudioCombo_SelectionChanged" Margin="0,0,10,0" Focusable="False"/>
            </StackPanel>

            <StackPanel Grid.Column="7" Orientation="Horizontal" Margin="5,5,10,5">
                <TextBlock Text="Internal Sub:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="SubTrackCombo" Width="120" SelectionChanged="SubTrackCombo_SelectionChanged" SelectedIndex="0" Focusable="False">
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="8" Orientation="Horizontal" Margin="5,5,10,5">
                <TextBlock Text="Crop:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button x:Name="CropIncBtn" Content="+" Foreground="White" Background="#404040" BorderThickness="0" Width="25" Click="CropIncBtn_Click" Focusable="False" Margin="0,0,2,0"/>
                <Button x:Name="CropDecBtn" Content="-" Foreground="White" Background="#404040" BorderThickness="0" Width="25" Click="CropDecBtn_Click" Focusable="False"/>
            </StackPanel>

            <StackPanel Grid.Column="9" Orientation="Horizontal" Margin="5,5,10,5">
                <TextBlock Text="Width:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button x:Name="SubWidthIncBtn" Content="+" Foreground="White" Background="#404040" BorderThickness="0" Width="25" Click="SubWidthIncBtn_Click" Focusable="False" Margin="0,0,2,0"/>
                <Button x:Name="SubWidthDecBtn" Content="-" Foreground="White" Background="#404040" BorderThickness="0" Width="25" Click="SubWidthDecBtn_Click" Focusable="False"/>
            </StackPanel>

            <Button x:Name="FullscreenBtn" Grid.Column="10" Content="Fullscreen" Foreground="White" Background="#404040" 
                    BorderThickness="0" Margin="5,5,5,5" Width="75" Click="FullscreenBtn_Click" Focusable="False"/>

            <Button x:Name="HelpBtn" Grid.Column="11" Content="?" Foreground="White" Background="#1E90FF" 
                    BorderThickness="0" Margin="5,5,5,5" Width="25" FontWeight="Bold" Click="HelpBtn_Click" Focusable="False"/>

            <StackPanel Grid.Column="12" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,10,0">
                <TextBlock x:Name="SizeStatus" Text="S:32" Foreground="#888888" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="HeightStatus" Text="H:0" Foreground="#888888" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="WidthStatus" Text="W:900" Foreground="#888888" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="CropStatus" Text="C:0" Foreground="#888888" FontSize="11"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>